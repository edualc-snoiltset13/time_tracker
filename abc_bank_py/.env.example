# Optional, all have sensible defaults.
BANK_DB_URL=sqlite:///./abc_bank.db
BANK_JWT_TTL_SECONDS=3600
BANK_SMTP_HOST=
BANK_SMTP_PORT=587
BANK_SMTP_USERNAME=
BANK_SMTP_PASSWORD=
BANK_SMTP_FROM=
